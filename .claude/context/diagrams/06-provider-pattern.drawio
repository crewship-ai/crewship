<mxfile host="app.diagrams.net" modified="2026-03-10" agent="Crewship" version="24.0.0" type="device">
  <diagram id="provider-pattern" name="Provider Pattern (K8s Readiness)">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="&lt;b&gt;CREWSHIP — Provider Pattern (K8s Readiness)&lt;/b&gt;&lt;br&gt;Swap implementation, not rewrite — env var per provider" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="650" y="20" width="530" height="50" as="geometry" />
        </mxCell>

        <!-- Business Logic -->
        <mxCell id="biz" value="&lt;b&gt;crewship&lt;/b&gt;&lt;br&gt;(business logic only — never accesses Docker/FS/bbolt directly)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=13;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="600" height="60" as="geometry" />
        </mxCell>

        <!-- ========== 3 PROVIDER INTERFACES ========== -->

        <!-- Container Provider -->
        <mxCell id="cp_iface" value="&lt;b&gt;ContainerProvider&lt;/b&gt;&lt;br&gt;(interface)" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#283593;fontSize=12;perimeter=hexagonPerimeter2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="240" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cp_docker" value="&lt;b&gt;Docker SDK&lt;/b&gt;&lt;br&gt;(exec, logs, lifecycle)&lt;br&gt;&lt;br&gt;✅ MVP — IMPLEMENTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="160" y="380" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cp_k8s" value="&lt;b&gt;client-go (K8s)&lt;/b&gt;&lt;br&gt;Pods, Jobs&lt;br&gt;&lt;br&gt;⏳ Enterprise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="380" width="150" height="80" as="geometry" />
        </mxCell>

        <!-- Storage Provider -->
