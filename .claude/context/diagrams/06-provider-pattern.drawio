          <mxGeometry x="680" y="240" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sp_local" value="&lt;b&gt;Local FS&lt;/b&gt;&lt;br&gt;+ fsnotify&lt;br&gt;&lt;br&gt;✅ MVP — IMPLEMENTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
