        <mxCell id="stp_bbolt" value="&lt;b&gt;bbolt&lt;/b&gt;&lt;br&gt;embedded WAL&lt;br&gt;&lt;br&gt;✅ MVP — IMPLEMENTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
