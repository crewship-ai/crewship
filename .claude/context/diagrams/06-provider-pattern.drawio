        <mxCell id="sp_s3" value="&lt;b&gt;S3 / MinIO&lt;/b&gt;&lt;br&gt;+ event notifications&lt;br&gt;&lt;br&gt;⏳ Enterprise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="380" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- State Provider -->
