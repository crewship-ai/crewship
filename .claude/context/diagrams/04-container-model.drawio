          <mxGeometry x="720" y="875" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fs_skills_mount" value="&lt;b&gt;/output/.skills/&lt;/b&gt;&lt;br&gt;installed skill files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="950" width="160" height="40" as="geometry" />
        </mxCell>
