        <!-- Sidecar components -->
        <mxCell id="sc_cred_store" value="&lt;b&gt;CredStore&lt;/b&gt;&lt;br&gt;In-memory credential store&lt;br&gt;Loaded from stdin JSON at start&lt;br&gt;Round-robin per provider" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="480" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sc_proxy" value="&lt;b&gt;HTTP Forward Proxy&lt;/b&gt;&lt;br&gt;Credential injection per-request:&lt;br&gt;• x-api-key (Anthropic)&lt;br&gt;• Bearer token (OpenAI)&lt;br&gt;• ?key= (Google)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="430" y="480" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sc_allowlist" value="&lt;b&gt;Domain Allowlist ✅&lt;/b&gt;&lt;br&gt;api.anthropic.com&lt;br&gt;api.openai.com&lt;br&gt;googleapis.com&lt;br&gt;api.factory.ai" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="570" width="160" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sc_memory" value="&lt;b&gt;Memory Engine ✅&lt;/b&gt;&lt;br&gt;SQLite FTS5 index&lt;br&gt;BM25 search&lt;br&gt;POST /memory/search&lt;br&gt;POST /memory/reindex&lt;br&gt;GET /memory/status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="580" width="170" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sc_assign" value="&lt;b&gt;Assignment Proxy ⏳&lt;/b&gt;&lt;br&gt;POST /assign&lt;br&gt;POST /ask&lt;br&gt;POST /broadcast&lt;br&gt;GET /results/:id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="680" width="160" height="90" as="geometry" />
