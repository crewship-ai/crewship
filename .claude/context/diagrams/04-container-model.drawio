        <!-- ========== SECURITY CONSTRAINTS ========== -->
        <mxCell id="sec_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="1400" y="340" width="500" height="680" as="geometry" />
        </mxCell>
        <mxCell id="sec_label" value="&lt;b&gt;SECURITY CONSTRAINTS&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="1420" y="345" width="210" height="25" as="geometry" />
        </mxCell>

        <mxCell id="sec1" value="🔒 &lt;b&gt;Non-root&lt;/b&gt;: Agent UID 1001, Sidecar UID 1002" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="380" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec2" value="🔒 &lt;b&gt;Network&lt;/b&gt;: --internal (no internet). Only allowlisted LLM APIs via sidecar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="420" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec3" value="🔒 &lt;b&gt;FS isolation&lt;/b&gt;: Agent sees only /workspace/ + /output/ (own agent dir)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="460" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec4" value="🔒 &lt;b&gt;No sudo&lt;/b&gt;: No setuid binaries, cap-drop ALL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="500" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec5" value="🔒 &lt;b&gt;Credential invisible&lt;/b&gt;: Agent gets DUMMY keys, sidecar injects real ones" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="540" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec6" value="🔒 &lt;b&gt;Stdout scrubbing&lt;/b&gt;: 13+ patterns redacted before WS/JSONL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="580" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec7" value="🔒 &lt;b&gt;Cross-UID isolation&lt;/b&gt;: kernel blocks /proc reads between 1001↔1002" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="620" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec8" value="🔒 &lt;b&gt;Resource limits&lt;/b&gt;: configurable RAM/CPU per crew" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1420" y="660" width="460" height="30" as="geometry" />
        </mxCell>

        <mxCell id="sec_future" value="&lt;b&gt;PLANNED:&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#C62828;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="710" width="80" height="25" as="geometry" />
        </mxCell>
        <mxCell id="sec9" value="⏳ &lt;b&gt;Landlock LSM&lt;/b&gt;: per-agent filesystem isolation within shared container" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="740" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec10" value="⏳ &lt;b&gt;srt sandbox&lt;/b&gt;: Each MCP server in Anthropic Sandbox Runtime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="780" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec11" value="⏳ &lt;b&gt;gVisor/runsc&lt;/b&gt;: Optional syscall interception for multi-tenant SaaS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="820" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec12" value="⏳ &lt;b&gt;iptables per-agent&lt;/b&gt;: Granular LLM API allowlists per agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="860" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec13" value="⏳ &lt;b&gt;MCP RBAC&lt;/b&gt;: Sidecar validates per-tool permissions before proxying" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="900" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec14" value="⏳ &lt;b&gt;Credential isolation&lt;/b&gt;: Agent has NO tool credentials; sidecar injects into MCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="940" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec15" value="⏳ &lt;b&gt;Tool call audit&lt;/b&gt;: Every MCP call logged with agent, tool, credential_id, ts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="980" width="460" height="30" as="geometry" />
