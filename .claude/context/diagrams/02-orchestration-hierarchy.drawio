        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;2&lt;/b&gt;&lt;br&gt;crewshipd starts&lt;br&gt;Docker exec for Lead" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="1130" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;3&lt;/b&gt;&lt;br&gt;Lead decides:&lt;br&gt;do it myself OR&lt;br&gt;assign to agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="1130" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;4&lt;/b&gt;&lt;br&gt;POST /assign to&lt;br&gt;sidecar (localhost:9119)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="840" y="1130" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="&lt;b&gt;5&lt;/b&gt;&lt;br&gt;Sidecar validates:&lt;br&gt;RBAC, circuit breaker,&lt;br&gt;target exists?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1130" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="&lt;b&gt;6&lt;/b&gt;&lt;br&gt;crewshipd starts&lt;br&gt;Docker exec for Agent&lt;br&gt;(same container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="1130" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="step7" value="&lt;b&gt;7&lt;/b&gt;&lt;br&gt;Agent works...&lt;br&gt;stdout → JSONL log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#80CBC4;strokeColor=#00695C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="1230" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step8" value="&lt;b&gt;8&lt;/b&gt;&lt;br&gt;Agent completes,&lt;br&gt;result → sidecar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#80CBC4;strokeColor=#00695C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="1230" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step9" value="&lt;b&gt;9&lt;/b&gt;&lt;br&gt;Lead reads result&lt;br&gt;via GET /results/:id&lt;br&gt;(or sidecar callback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9FA8DA;strokeColor=#283593;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="1230" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step10" value="&lt;b&gt;10&lt;/b&gt;&lt;br&gt;Lead aggregates,&lt;br&gt;responds to user&lt;br&gt;via stdout → WebSocket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9FA8DA;strokeColor=#283593;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="1230" width="160" height="60" as="geometry" />
