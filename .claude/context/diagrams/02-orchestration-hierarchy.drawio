        <!-- Flow steps -->
        <mxCell id="step1" value="&lt;b&gt;1&lt;/b&gt;&lt;br&gt;User sends message&lt;br&gt;to Lead via WebSocket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
