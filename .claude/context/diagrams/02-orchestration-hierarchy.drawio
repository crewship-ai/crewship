        <mxCell id="mode_active" value="&lt;b&gt;Active Mode&lt;/b&gt; (default)&lt;br&gt;&lt;hr&gt;Lead runs during entire Mission&lt;br&gt;Real-time decisions&lt;br&gt;Can change strategy mid-flight&lt;br&gt;&lt;br&gt;💰 Higher cost (continuous LLM)&lt;br&gt;✅ Flexible, iterative" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
