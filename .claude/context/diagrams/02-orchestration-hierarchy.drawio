        </mxCell>

        <mxCell id="mode_passive" value="&lt;b&gt;Passive Mode&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Lead runs 2x:&lt;br&gt;  1. Init (task breakdown)&lt;br&gt;  2. Finalize (aggregate)&lt;br&gt;&lt;br&gt;💰 Lower cost (2 LLM calls)&lt;br&gt;⚠️ Cannot adapt mid-run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
