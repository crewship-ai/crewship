        <mxCell id="coordinator" value="&lt;b&gt;🏢 Coordinator&lt;/b&gt;&lt;br&gt;&lt;br&gt;1 per workspace (opt-in)&lt;br&gt;Lightweight LLM call&lt;br&gt;(NO Docker container)&lt;br&gt;&lt;br&gt;Knows all crews &amp; leads&lt;br&gt;Cross-crew coordination&lt;br&gt;Strategic aggregation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
