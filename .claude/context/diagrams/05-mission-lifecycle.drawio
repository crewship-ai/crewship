        <mxCell id="loop_label" value="&lt;b&gt;DEV-TEST LOOP (Workflow Template, Phase 2B)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#7B1FA2;" vertex="1" parent="1">
          <mxGeometry x="1020" y="715" width="380" height="25" as="geometry" />
        </mxCell>

        <mxCell id="loop_dev" value="&lt;b&gt;Developer&lt;/b&gt;&lt;br&gt;implements feature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="770" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="loop_test" value="&lt;b&gt;Tester&lt;/b&gt;&lt;br&gt;runs tests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1300" y="770" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="loop_check" value="&lt;b&gt;Tests pass?&lt;/b&gt;" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1300" y="860" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="loop_done" value="&lt;b&gt;✅ Done&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1500" y="870" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="loop_retry" value="&lt;b&gt;iteration++&lt;/b&gt;&lt;br&gt;(with error context)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1050" y="870" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="loop_max" value="&lt;b&gt;max_iterations&lt;/b&gt;&lt;br&gt;reached → FAILED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1050" y="940" width="140" height="40" as="geometry" />
        </mxCell>

        <mxCell id="el1" style="rounded=1;strokeWidth=2;" edge="1" source="loop_dev" target="loop_test" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el2" style="rounded=1;strokeWidth=2;" edge="1" source="loop_test" target="loop_check" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el3" value="YES" style="rounded=1;fontSize=10;" edge="1" source="loop_check" target="loop_done" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el4" value="NO" style="rounded=1;fontSize=10;strokeColor=#C62828;" edge="1" source="loop_check" target="loop_retry" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="el5" style="rounded=1;strokeColor=#C62828;dashed=1;" edge="1" source="loop_retry" target="loop_dev" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== DUAL STORAGE ========== -->
        <mxCell id="storage_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="1100" width="1600" height="200" as="geometry" />
        </mxCell>
        <mxCell id="storage_label" value="&lt;b&gt;DUAL STORAGE: DB + JSONL Mirror&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="100" y="1105" width="270" height="25" as="geometry" />
        </mxCell>

        <mxCell id="store_db" value="&lt;b&gt;SQLite / PostgreSQL&lt;/b&gt;&lt;br&gt;(Source of Truth)&lt;br&gt;&lt;hr&gt;missions table&lt;br&gt;mission_tasks table&lt;br&gt;UI queries, dashboard" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="1150" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="store_jsonl" value="&lt;b&gt;progress.jsonl&lt;/b&gt;&lt;br&gt;(Mirror — agents read this)&lt;br&gt;&lt;hr&gt;/output/{lead}/mission-{id}/&lt;br&gt;Append-only, real-time&lt;br&gt;External state for iterations" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="450" y="1150" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="store_ws" value="&lt;b&gt;WebSocket events&lt;/b&gt;&lt;br&gt;(Real-time UI updates)&lt;br&gt;&lt;hr&gt;mission.created&lt;br&gt;task.status&lt;br&gt;task.progress&lt;br&gt;mission.completed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="1150" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="es_sync" value="sync" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;strokeWidth=2;" edge="1" source="store_db" target="store_jsonl" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es_ws" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;strokeWidth=2;" edge="1" source="store_db" target="store_ws" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
