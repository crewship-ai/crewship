        <mxCell id="ess5" style="rounded=0;fontSize=9;" edge="1" source="ss5" target="ss6" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Engine reads files -->
        <mxCell id="e_engine_files" value="reads .md files" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;strokeColor=#388E3C;dashed=1;" edge="1" source="eng_fts5" target="fs_box" parent="1">
