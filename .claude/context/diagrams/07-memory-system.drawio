<mxfile host="app.diagrams.net" modified="2026-03-10" agent="Crewship" version="24.0.0" type="device">
  <diagram id="memory-system" name="Memory System (4 Layers)">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="&lt;b&gt;CREWSHIP — 4-Layer Memory System&lt;/b&gt;&lt;br&gt;File-first + SQLite FTS5 index — zero external deps" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="700" y="20" width="480" height="50" as="geometry" />
        </mxCell>

        <!-- ========== 4 LAYERS ========== -->

        <!-- Layer 4: Workspace -->
        <mxCell id="l4" value="&lt;b&gt;LAYER 4: WORKSPACE MEMORY&lt;/b&gt;  (Phase 3)&lt;br&gt;&lt;hr&gt;&lt;b&gt;Where:&lt;/b&gt; /var/lib/crewship/memory/{workspace-id}/&lt;br&gt;&lt;b&gt;Managed by:&lt;/b&gt; crewshipd (Go process)&lt;br&gt;&lt;b&gt;Read by:&lt;/b&gt; Coordinator (via lightweight LLM call)&lt;br&gt;&lt;b&gt;Content:&lt;/b&gt; Strategic goals, KPIs, cross-crew decisions, org policies&lt;br&gt;&lt;b&gt;RBAC:&lt;/b&gt; OWNER/ADMIN write, Coordinator read" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;align=left;spacingLeft=15;verticalAlign=top;spacingTop=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="500" height="140" as="geometry" />
        </mxCell>

        <!-- Layer 3: Crew -->
        <mxCell id="l3" value="&lt;b&gt;LAYER 3: CREW MEMORY&lt;/b&gt;  (Phase 2B)&lt;br&gt;&lt;hr&gt;&lt;b&gt;Where:&lt;/b&gt; /output/.crew-memory/{crew-slug}/&lt;br&gt;&lt;b&gt;Managed by:&lt;/b&gt; crewship-sidecar&lt;br&gt;&lt;b&gt;Read by:&lt;/b&gt; Lead (direct FS), Agents (via sidecar HTTP)&lt;br&gt;&lt;b&gt;Content:&lt;/b&gt; Crew decisions, shared facts, project state&lt;br&gt;&lt;b&gt;RBAC:&lt;/b&gt; Lead write, Agents read-only (via sidecar)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#283593;fontSize=11;align=left;spacingLeft=15;verticalAlign=top;spacingTop=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="250" width="500" height="140" as="geometry" />
        </mxCell>

        <!-- Layer 2: Agent (MVP!) -->
        <mxCell id="l2" value="&lt;b&gt;LAYER 2: AGENT MEMORY&lt;/b&gt;  ✅ Phase 1 MVP (~70% done)&lt;br&gt;&lt;hr&gt;&lt;b&gt;Where:&lt;/b&gt; /output/{agent-slug}/.memory/&lt;br&gt;&lt;b&gt;Managed by:&lt;/b&gt; crewship-sidecar (MCP tools)&lt;br&gt;&lt;b&gt;Read by:&lt;/b&gt; Agent (MCP tools), Lead (sidecar read)&lt;br&gt;&lt;b&gt;Content:&lt;/b&gt; Agent identity, learned facts, daily logs&lt;br&gt;&lt;b&gt;RBAC:&lt;/b&gt; Agent write/read (own), Lead read (crew scope)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;align=left;spacingLeft=15;verticalAlign=top;spacingTop=5;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="100" y="410" width="500" height="140" as="geometry" />
        </mxCell>

        <!-- Layer 1: Session -->
        <mxCell id="l1" value="&lt;b&gt;LAYER 1: SESSION MEMORY&lt;/b&gt;  (Phase 2)&lt;br&gt;&lt;hr&gt;&lt;b&gt;Where:&lt;/b&gt; JSONL transcripts (existing) + SQLite session index&lt;br&gt;&lt;b&gt;Managed by:&lt;/b&gt; crewshipd (existing JSONL writer)&lt;br&gt;&lt;b&gt;Read by:&lt;/b&gt; Agent (via MCP memory_search — opt-in)&lt;br&gt;&lt;b&gt;Content:&lt;/b&gt; Recent conversations, task context&lt;br&gt;&lt;b&gt;RBAC:&lt;/b&gt; Agent reads only OWN sessions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;align=left;spacingLeft=15;verticalAlign=top;spacingTop=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="570" width="500" height="140" as="geometry" />
        </mxCell>

        <!-- ========== AGENT MEMORY DETAIL (Layer 2) ========== -->
        <mxCell id="detail_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="700" y="90" width="800" height="620" as="geometry" />
        </mxCell>
        <mxCell id="detail_label" value="&lt;b&gt;AGENT MEMORY DETAIL (Layer 2 — MVP)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="720" y="95" width="320" height="25" as="geometry" />
        </mxCell>

        <!-- File structure -->
        <mxCell id="fs_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="720" y="130" width="350" height="280" as="geometry" />
        </mxCell>
        <mxCell id="fs_title" value="&lt;b&gt;/output/{agent}/.memory/&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#2E7D32;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="730" y="135" width="230" height="20" as="geometry" />
        </mxCell>

        <mxCell id="f_agent_md" value="&lt;b&gt;AGENT.md&lt;/b&gt; ✅&lt;br&gt;Long-term curated memory&lt;br&gt;(identity, facts, preferences)&lt;br&gt;Loaded at EVERY session start&lt;br&gt;No temporal decay (evergreen)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="165" width="210" height="90" as="geometry" />
        </mxCell>

        <mxCell id="f_daily" value="&lt;b&gt;daily/&lt;/b&gt; ✅&lt;br&gt;├── 2026-03-10.md (today)&lt;br&gt;├── 2026-03-09.md (yesterday)&lt;br&gt;└── ... (searchable via FTS5)&lt;br&gt;Append-only daily logs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#388E3C;fontSize=10;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="740" y="265" width="250" height="90" as="geometry" />
        </mxCell>

        <mxCell id="f_index" value="&lt;b&gt;index.sqlite&lt;/b&gt; ✅ (DERIVED)&lt;br&gt;FTS5 index — can delete &amp; rebuild&lt;br&gt;Markdown = source of truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="365" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- Sidecar Memory Engine -->
        <mxCell id="engine_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="1100" y="130" width="370" height="350" as="geometry" />
        </mxCell>
        <mxCell id="engine_label" value="&lt;b&gt;crewship-sidecar — Memory Engine&lt;/b&gt;&lt;br&gt;(runs in container, localhost:9119)" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="1110" y="135" width="300" height="30" as="geometry" />
        </mxCell>

        <mxCell id="eng_fts5" value="&lt;b&gt;SQLite FTS5 Search ✅&lt;/b&gt;&lt;br&gt;BM25 ranking&lt;br&gt;unicode61 tokenizer&lt;br&gt;(CZ/SK diacritics)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1120" y="175" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eng_chunker" value="&lt;b&gt;Markdown Chunker ✅&lt;/b&gt;&lt;br&gt;~500 char chunks&lt;br&gt;## heading boundaries&lt;br&gt;~80 char overlap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1310" y="175" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eng_reindex" value="&lt;b&gt;Reindex ✅&lt;/b&gt;&lt;br&gt;POST /memory/reindex" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="260" width="160" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eng_search" value="&lt;b&gt;Search ✅&lt;/b&gt;&lt;br&gt;POST /memory/search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1290" y="260" width="160" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eng_status" value="&lt;b&gt;Status ✅&lt;/b&gt;&lt;br&gt;GET /memory/status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF9A9A;strokeColor=#C62828;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="305" width="160" height="35" as="geometry" />
        </mxCell>

        <!-- Not implemented yet -->
        <mxCell id="eng_write" value="&lt;b&gt;Write ⏳&lt;/b&gt;&lt;br&gt;POST /memory/write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="355" width="140" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eng_read" value="&lt;b&gt;Read ⏳&lt;/b&gt;&lt;br&gt;GET /memory/read" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1270" y="355" width="140" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eng_watch" value="&lt;b&gt;fsnotify watcher ⏳&lt;/b&gt;&lt;br&gt;auto-reindex on .md change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="400" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eng_vec" value="&lt;b&gt;Vector search ⏳&lt;/b&gt;&lt;br&gt;sqlite-vec (Phase 2)&lt;br&gt;Hybrid BM25 + vector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="445" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- Agent -> Sidecar -->
        <mxCell id="agent_proc" value="&lt;b&gt;Agent Process&lt;/b&gt;&lt;br&gt;(CLI / crewship-agent)&lt;br&gt;&lt;br&gt;CANNOT access .memory/ FS!&lt;br&gt;Uses ONLY sidecar API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B2EBF2;strokeColor=#00838F;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1100" y="530" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e_agent_engine" value="HTTP localhost:9119&lt;br&gt;memory_search / memory_write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;strokeWidth=2;strokeColor=#C62828;" edge="1" source="agent_proc" target="eng_search" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Session start flow -->
        <mxCell id="session_flow" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="720" y="440" width="350" height="270" as="geometry" />
        </mxCell>
        <mxCell id="session_label" value="&lt;b&gt;Session Start — Memory Loading ✅&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="735" y="445" width="280" height="25" as="geometry" />
        </mxCell>

        <mxCell id="ss1" value="1. crewshipd starts Docker exec" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="480" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ss2" value="2. Read AGENT.md (full)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="510" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ss3" value="3. Read daily/{today}.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="540" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ss4" value="4. Read daily/{yesterday}.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="570" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ss5" value="5. Inject [AGENT MEMORY] block&lt;br&gt;   into system prompt (max 15k chars)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="600" width="300" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ss6" value="6. Agent starts with full context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="740" y="645" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="ess1" style="rounded=0;fontSize=9;" edge="1" source="ss1" target="ss2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ess2" style="rounded=0;fontSize=9;" edge="1" source="ss2" target="ss3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
