# Crewship -- Environment Variables
# Copy to .env.local and fill in values

# Database (local PostgreSQL via Docker Compose)
DATABASE_URL=postgresql://crewship:crewship@localhost:5432/crewship

# NextAuth.js (Auth.js v5)
NEXTAUTH_SECRET=           # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Credentials vault
ENCRYPTION_KEY=            # openssl rand -hex 32

# Go service (crewshipd)
# Dev: /tmp/crewship.sock (ok for local dev)
# Production: /run/crewship/crewship.sock (with chmod 0660)
CREWSHIPD_SOCKET=/tmp/crewship.sock

# OAuth providers (optional)
# GITHUB_ID=
# GITHUB_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (Phase 2+)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Email (Phase 2+)
# RESEND_API_KEY=
