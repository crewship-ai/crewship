# Crewship -- Environment Variables
# Copy to .env and fill in values:
#   cp .env.example .env

# Database (SQLite is default, PostgreSQL is opt-in)
# SQLite (default -- zero deps, single file):
DATABASE_URL="file:./crewship.db"
# PostgreSQL (opt-in -- for teams, multi-user):
# DATABASE_URL=postgresql://crewship:change-me-in-production@localhost:5432/crewship

# Next.js
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
ENCRYPTION_KEY=           # openssl rand -hex 32

# crewshipd IPC
CREWSHIPD_URL=unix:///tmp/crewship.sock
CREWSHIP_NEXTJS_URL=http://localhost:3000    # Next.js URL for IPC resolver
CREWSHIP_INTERNAL_TOKEN=                     # shared secret for IPC auth (openssl rand -hex 16)

# crewshipd providers
CREWSHIP_CONTAINER_PROVIDER=docker
CREWSHIP_STORAGE_PROVIDER=localfs
CREWSHIP_STATE_PROVIDER=bbolt

# PostgreSQL (only if using PostgreSQL mode)
# POSTGRES_USER=crewship
# POSTGRES_PASSWORD=change-me-in-production
# POSTGRES_DB=crewship
