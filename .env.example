# Crewship -- Environment Variables
# Copy to .env and fill in values:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=crewship
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=crewship

# Next.js
DATABASE_URL=postgresql://crewship:change-me-in-production@localhost:5432/crewship
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
ENCRYPTION_KEY=           # openssl rand -hex 32

# crewshipd
CREWSHIP_CONTAINER_PROVIDER=docker
CREWSHIP_STORAGE_PROVIDER=localfs
CREWSHIP_STATE_PROVIDER=bbolt
