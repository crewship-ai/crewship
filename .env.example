# Crewship -- Environment Variables
# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Every CREWSHIP_* variable the binary reads at startup is documented
# below. Categories appear in the order an operator typically encounters
# them: required, listen/network, storage, container, auth/security,
# observability, integrations, behaviour knobs, dev-only skip flags.
# Audit M20 follow-up.

# ─── REQUIRED ────────────────────────────────────────────────────────────────

NEXTAUTH_SECRET=           # openssl rand -base64 32 (JWT signing)
ENCRYPTION_KEY=            # openssl rand -hex 32 (credential encryption)

# Database (SQLite is default, PostgreSQL is opt-in)
DATABASE_URL="file:./crewship.db"
# PostgreSQL (opt-in): DATABASE_URL=postgresql://user:pass@localhost:5432/crewship

# ─── LISTEN / NETWORK ────────────────────────────────────────────────────────

CREWSHIP_PORT=8080
# CREWSHIP_HOST=                       # bind address; default 0.0.0.0 (all interfaces)
# CREWSHIP_PUBLIC_URL=https://crewship.example.com
#                                       # canonical external URL; used for OAuth callbacks
# CREWSHIP_NEXTJS_URL=                  # next.js dev server (dev only); production embeds it
# CREWSHIP_ALLOWED_ORIGINS=             # comma-separated CORS allowlist
# CREWSHIP_TRUSTED_PROXY_CIDRS=         # CIDR list of HTTPS-terminating proxies
#                                       # (X-Forwarded-For / X-Real-IP only honored from these)

# ─── STORAGE PROVIDERS ───────────────────────────────────────────────────────

CREWSHIP_CONTAINER_PROVIDER=docker      # docker | k8s
CREWSHIP_STORAGE_PROVIDER=localfs       # localfs | s3
CREWSHIP_STATE_PROVIDER=bbolt           # bbolt | postgres
# CREWSHIP_DATA_DIR=/var/lib/crewship   # parent of storage/logs/state on disk
# CREWSHIP_STORAGE_BASE_PATH=           # crew/agent workspace volumes (defaults under DATA_DIR)
# CREWSHIP_LOG_PATH=                    # agent log directory (defaults under DATA_DIR)
# CREWSHIP_BOLT_PATH=                   # bbolt state file (defaults under DATA_DIR)

# ─── CONTAINER RUNTIME ───────────────────────────────────────────────────────

# CREWSHIP_RUNTIME=                     # docker | colima | orbstack | rancher (auto-detect)
# CREWSHIP_RUNTIME_IMAGE=               # override the agent runtime image; default crewship-runtime
# CREWSHIP_CONTAINER_NETWORK=crewship-agents
# CREWSHIP_CONTAINER_PREFIX=crewship    # prefix for spawned container names
# CREWSHIP_ENTRYPOINT_PATH=             # override the entrypoint binary path inside the image
# CREWSHIP_SIDECAR_PATH=                # override the sidecar binary path inside the image
# CREWSHIP_SOCKET_PATH=                 # unix socket for the IPC server (default /tmp/crewship.sock)

# ─── AUTH / SECURITY ─────────────────────────────────────────────────────────

# CREWSHIP_INTERNAL_TOKEN=              # openssl rand -hex 16 — sidecar↔server auth.
#                                       # When unset the server generates a fresh token at boot
#                                       # and rotates it on every restart; pin a value here only
#                                       # when multiple instances must share the IPC bus.
CREWSHIP_ADMIN_TOKEN_HMAC_KEY=          # openssl rand -hex 32 — HMAC key for the cli_tokens table
#                                       # (admin/share tokens are hashed at rest with this key).
#                                       # REQUIRED in production; missing → cli_token endpoints 503.
# CREWSHIP_FORCE_SECURE_COOKIES=true    # force Secure flag on auth cookies even when X-Forwarded-Proto
#                                       # is dropped by the proxy. Audit M27. Set behind any HTTPS edge.
#
# DANGER FLAGS — only for non-prod debugging. Refused in CREWSHIP_ENV=prod.
# CREWSHIP_INTERNAL_ALLOW_ANY=1         # disables internal-IPC bearer check (DEV ONLY)
# CREWSHIP_RATELIMIT_DISABLED=1         # disables per-IP rate limiter (DEV ONLY); refused in prod

# ─── ENVIRONMENT TAG ─────────────────────────────────────────────────────────

# CREWSHIP_ENV=prod                     # any of: dev | staging | prod (or production)
#                                       # prod toggles fail-closed for the danger flags above
# CREWSHIP_VERSION=                     # ldflag-baked at build time; not normally set by ops

# ─── LICENSING / BILLING ─────────────────────────────────────────────────────

# CREWSHIP_LICENSE_FILE=                # path to crewship.lic; absent = community tier
# CREWSHIP_SUBSCRIPTION_PLAN=           # plan slug, paired with license
# CREWSHIP_BILLING_MODE=                # passthrough | aggregated (paymaster routing)
# CREWSHIP_FORECAST_RATES=              # JSON: per-model unit price overrides for the forecaster

# ─── LOGGING ─────────────────────────────────────────────────────────────────

# CREWSHIP_LOG_LEVEL=info               # debug | info | warn | error
# CREWSHIP_LOG_FORMAT=json              # json | text

# ─── OBSERVABILITY ───────────────────────────────────────────────────────────

# CREWSHIP_METRICS_TOKEN=               # bearer token gating /metrics. Unset = metrics disabled.
# CREWSHIP_SENTRY_DSN=                  # backend crash reporting; absent = no Sentry init

# ─── BACKUPS ─────────────────────────────────────────────────────────────────

# CREWSHIP_BACKUP_WEBHOOK_URL=          # POST'd on every backup completion
# CREWSHIP_BACKUP_WEBHOOK_SECRET=       # HMAC signing key for the webhook payload

# ─── BEHAVIOUR KNOBS ─────────────────────────────────────────────────────────

# CREWSHIP_WORKSPACE=                   # default workspace slug for single-tenant deploys
# CREWSHIP_DEFAULT_AGENT=               # auto-select this agent slug in the dashboard
# CREWSHIP_QUERY_DEPTH=                 # default depth for nested graph queries
# CREWSHIP_PIPELINE_RUNNER=             # pipeline executor profile
# CREWSHIP_CONSOLIDATE_HITL=            # human-in-the-loop gate for memory consolidation
# CREWSHIP_NOTIFY_LONG_RUN=             # threshold (seconds) for the "long run" notification

# ─── DEV-ONLY SKIP FLAGS ─────────────────────────────────────────────────────

# CREWSHIP_SKIP_MIGRATION_BACKUP=1      # skip the pre-migration .db snapshot (NEVER in prod)
# CREWSHIP_SKIP_SIDECAR=1               # skip sidecar boot for unit-style local runs
# CREWSHIP_SKIP_UPDATE_CHECK=1          # skip the daily "new version available" probe
# CREWSHIP_E2E_SKIP_TOKEN_PROBE=1       # bypass token probe in CI E2E runs

# ─── KEEPER (credential access control via local AI) ─────────────────────────

# Setting KEEPER_OLLAMA_URL automatically enables Keeper.
# KEEPER_OLLAMA_URL=http://localhost:11434
# KEEPER_MODEL=phi3:mini                # Ollama model for gatekeeper decisions

# ─── FRONTEND (Sentry, baked into the static bundle at build time) ───────────

# These are CONSUMED AT BUILD TIME ONLY. The release.yml / nightly.yml
# workflows set them from repo secrets and the ldflag-baked tag; local
# `pnpm build` leaves them empty, which makes the Sentry client a no-op
# (no DSN -> no init -> no network). Empty is the safe default.
# NEXT_PUBLIC_SENTRY_DSN=               # https://<key>@<org>.ingest.sentry.io/<project>
# NEXT_PUBLIC_CREWSHIP_VERSION=         # e.g. v0.1.0-beta.1 or nightly-<sha>

# ─── MULTI-INSTANCE DEV ENVIRONMENT ──────────────────────────────────────────

# When the project directory is named crewship_N (e.g. crewship_1, crewship_2),
# ./dev.sh auto-generates these values. No manual setup needed.
# Port schema: GO=8080+N, NEXT=3010+N, PG=5432+N
#   Instance 1 (crewship_1): Go :8081, Next.js :3011, PG :5433
#   Instance 2 (crewship_2): Go :8082, Next.js :3012, PG :5434
#   Instance 3 (crewship_3): Go :8083, Next.js :3013, PG :5435
# These are written to .env.local by `./dev.sh start`:
# NEXT_PUBLIC_GO_PORT=8081
# NEXT_PUBLIC_WS_URL=ws://localhost:8081/ws
# NEXTAUTH_URL=http://localhost:3011
# CREWSHIP_PORT=8081
# CREWSHIP_SOCKET_PATH=/tmp/crewship-1.sock
# CREWSHIP_CONTAINER_NETWORK=crewship-1-agents
# CREWSHIP_STORAGE_BASE_PATH=/tmp/crewship-1-data
# CREWSHIP_LOG_PATH=/tmp/crewship-1-logs
# CREWSHIP_BOLT_PATH=/tmp/crewship-1-state/state.db
