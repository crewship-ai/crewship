# Crewship -- Environment Variables
# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# Required
NEXTAUTH_SECRET=           # openssl rand -base64 32 (JWT signing)
ENCRYPTION_KEY=            # openssl rand -hex 32 (credential encryption)

# Database (SQLite is default, PostgreSQL is opt-in)
DATABASE_URL="file:./crewship.db"
# PostgreSQL (opt-in): DATABASE_URL=postgresql://user:pass@localhost:5432/crewship

# Optional (defaults shown)
CREWSHIP_PORT=8080

# Provider selection (defaults)
CREWSHIP_CONTAINER_PROVIDER=docker    # docker | k8s
CREWSHIP_STORAGE_PROVIDER=localfs     # localfs | s3
CREWSHIP_STATE_PROVIDER=bbolt         # bbolt | postgres

# Internal IPC (advanced -- leave empty for defaults)
CREWSHIP_INTERNAL_TOKEN=              # openssl rand -hex 16

# Keeper -- credential access control via local AI (Ollama)
# Setting KEEPER_OLLAMA_URL automatically enables Keeper.
# KEEPER_OLLAMA_URL=http://localhost:11434
# KEEPER_MODEL=phi3:mini              # Ollama model for gatekeeper decisions

# Sentry (frontend crash reporting -- baked into the static bundle at build)
# These are CONSUMED AT BUILD TIME ONLY. The release.yml / nightly.yml
# workflows set them from repo secrets and the ldflag-baked tag; local
# `pnpm build` leaves them empty, which makes the Sentry client a no-op
# (no DSN -> no init -> no network). Empty is the safe default.
# NEXT_PUBLIC_SENTRY_DSN=             # https://<key>@<org>.ingest.sentry.io/<project>
# NEXT_PUBLIC_CREWSHIP_VERSION=       # e.g. v0.1.0-beta.1 or nightly-<sha>; controls Sentry "environment"

# Multi-instance dev environment
# When the project directory is named crewship_N (e.g. crewship_1, crewship_2),
# ./dev.sh auto-generates these values. No manual setup needed.
# Port schema: GO=8080+N, NEXT=3010+N, PG=5432+N
#   Instance 1 (crewship_1): Go :8081, Next.js :3011, PG :5433
#   Instance 2 (crewship_2): Go :8082, Next.js :3012, PG :5434
#   Instance 3 (crewship_3): Go :8083, Next.js :3013, PG :5435
# These are written to .env.local by `./dev.sh start`:
# NEXT_PUBLIC_GO_PORT=8081
# NEXT_PUBLIC_WS_URL=ws://localhost:8081/ws
# NEXTAUTH_URL=http://localhost:3011
# CREWSHIP_PORT=8081
# CREWSHIP_SOCKET_PATH=/tmp/crewship-1.sock
# CREWSHIP_CONTAINER_NETWORK=crewship-1-agents
# CREWSHIP_STORAGE_BASE_PATH=/tmp/crewship-1-data
# CREWSHIP_LOG_PATH=/tmp/crewship-1-logs
# CREWSHIP_BOLT_PATH=/tmp/crewship-1-state/state.db
