# Crewship server environment — read by the crewship.service systemd unit
# (EnvironmentFile=/etc/crewship/crewship.env).
#
# Installed as a config file: your edits survive package upgrades. The two
# secrets below are REQUIRED — `crewship start` refuses to boot without them
# and prints these same openssl one-liners.

# Session signing secret. Generate once:
#   openssl rand -hex 32
NEXTAUTH_SECRET=

# Credential-vault encryption key (32 bytes, hex-encoded = 64 chars):
#   openssl rand -hex 32
ENCRYPTION_KEY=

# --- Optional overrides (uncomment to change) ---

# Listen address for the dashboard + API.
# CREWSHIP_PORT=8080

# Container runtime. Leave as docker for local agents; set to skip container
# startup on a dashboard-only host (equivalent to `crewship start --no-docker`).
# CREWSHIP_CONTAINER_PROVIDER=docker

# Base image agents run in.
# CREWSHIP_RUNTIME_IMAGE=debian:bookworm-slim
