# Crewship server environment — read by the crewship.service systemd unit
# (EnvironmentFile=/etc/crewship/crewship.env).
#
# Everything here is OPTIONAL. Installed as a config file, so your edits survive
# package upgrades. Uncomment and set only what you want to override.
#
# You do NOT set the crypto secrets here: crewship auto-generates ENCRYPTION_KEY
# and NEXTAUTH_SECRET on first start and persists them to
# /var/lib/crewship/secrets.env (mode 0600). Leave that to the server.

# Extra arguments appended to `crewship start`. The most common use is running
# dashboard-only on a host with no container runtime (agents disabled):
# CREWSHIP_ARGS=--no-docker

# Listen port for the dashboard + API (default 8080).
# CREWSHIP_PORT=8080

# Base image agents run in (default debian:bookworm-slim).
# CREWSHIP_RUNTIME_IMAGE=debian:bookworm-slim

# Container runtime: docker | apple | auto (default docker). This does NOT skip
# containers — use CREWSHIP_ARGS=--no-docker above for a dashboard-only host.
# CREWSHIP_CONTAINER_PROVIDER=docker
